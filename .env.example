# Supabase Postgres (Transaction pooler, port 6543)
# Project Settings → Database → Connection string → URI (Transaction)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Auth (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App URL (local or Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Single-user lock — only this email can use the app (comma-separated ok)
ALLOWED_EMAIL=you@example.com

# OpenRouter (AI tagging)
OPENROUTER_API_KEY=your-openrouter-key

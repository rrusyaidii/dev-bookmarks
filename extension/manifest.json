{
  "manifest_version": 3,
  "name": "DevMark Saver",
  "version": "1.1.0",
  "description": "One-click save the current tab to your DevMark app (local or Vercel).",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*.vercel.app/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to DevMark"
  },
  "options_page": "options.html"
}
